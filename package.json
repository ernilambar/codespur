{
  "name": "coblink",
  "version": "1.0.0",
  "description": "AI-powered PR reviewer.",
  "keywords": [
    "ai",
    "code-review",
    "pr-review",
    "llm",
    "cli",
    "bun"
  ],
  "homepage": "https://github.com/ernilambar/coblink",
  "bugs": {
    "url": "https://github.com/ernilambar/coblink/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ernilambar/coblink.git"
  },
  "license": "MIT",
  "author": "Nilambar Sharma <nilambar@outlook.com> (https://www.nilambar.net)",
  "type": "module",
  "bin": {
    "coblink": "./coblink.ts"
  },
  "scripts": {
    "build": "bun build ./coblink.ts --compile --outfile coblink",
    "build:all": "bun build ./coblink.ts --compile --target=bun-darwin-arm64 --outfile dist/coblink-darwin-arm64",
    "build:min": "bun build ./coblink.ts --compile --minify --sourcemap=none --outfile coblink",
    "review": "bun run coblink.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
