{
  "name": "codespur",
  "version": "1.0.0",
  "description": "AI-powered PR reviewer.",
  "keywords": [
    "ai",
    "code-review",
    "pr-review",
    "llm",
    "cli",
    "bun"
  ],
  "homepage": "https://github.com/ernilambar/codespur",
  "bugs": {
    "url": "https://github.com/ernilambar/codespur/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ernilambar/codespur.git"
  },
  "license": "MIT",
  "author": "Nilambar Sharma <nilambar@outlook.com> (https://www.nilambar.net)",
  "type": "module",
  "bin": {
    "codespur": "./codespur.ts"
  },
  "scripts": {
    "build": "bun build ./codespur.ts --compile --outfile codespur",
    "build:all": "bun build ./codespur.ts --compile --target=bun-darwin-arm64 --outfile dist/codespur-darwin-arm64",
    "build:min": "bun build ./codespur.ts --compile --minify --sourcemap=none --outfile codespur",
    "review": "bun run codespur.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
